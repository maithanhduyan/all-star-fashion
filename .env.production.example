# ============================================
# All Star Fashion — Production Environment
# ============================================
# Copy this to .env and change ALL values!
# DO NOT commit .env to git.
# ============================================

# Database
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=allstar_fashion
DATABASE_USER=allstar
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# App
APP_ENV=production
APP_PORT=8000
APP_URL=https://allstarfashion.vn

# Session — Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_GENERATE_64_HEX_CHARS
SESSION_MAX_AGE=2592000

# Admin (seed script creates this user)
ADMIN_EMAIL=admin@allstarfashion.vn
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Shipping (VND)
FREE_SHIPPING_THRESHOLD=1000000
DEFAULT_SHIPPING_FEE=30000
